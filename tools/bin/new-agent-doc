#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-agent-doc <agent-slug>"
  echo
  echo "Example:"
  echo "  new-agent-doc security-reviewer"
  exit 1
fi

SLUG="$1"

case "$SLUG" in
  *[!a-z0-9-]*|"")
    echo "Agent slug must use only lowercase letters, numbers, and hyphens."
    echo "Example: security-reviewer"
    exit 1
    ;;
esac

ROOT="$PWD"
while [ "$ROOT" != "/" ]; do
  if [ -f "$ROOT/AGENTS.md" ] && [ -d "$ROOT/docs" ]; then
    break
  fi
  ROOT="$(dirname "$ROOT")"
done

if [ "$ROOT" = "/" ]; then
  echo "Workspace root not found."
  echo "Run this inside an agent-ready workspace."
  exit 1
fi

TARGET="$ROOT/agents/$SLUG.md"

if [ -e "$TARGET" ]; then
  echo "Agent already exists:"
  echo "  $TARGET"
  exit 1
fi

mkdir -p "$ROOT/agents"

TITLE="$(echo "$SLUG" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) substr($i,2)}; print}') Agent"

cat > "$TARGET" <<EOF2
# $TITLE

------------------------------------------------------------

## Purpose

Describe what this agent is responsible for.

------------------------------------------------------------

## Use When

Use this agent when:

- condition 1
- condition 2
- condition 3

------------------------------------------------------------

## Responsibilities

- responsibility 1
- responsibility 2
- responsibility 3

------------------------------------------------------------

## Restrictions

This agent must not:

- edit files unless approved
- commit unless requested
- push unless requested
- expose secrets
- run destructive commands

------------------------------------------------------------

## Output Format

Return:

- summary
- findings
- risks
- recommendation
- next step

------------------------------------------------------------
EOF2

echo "Created agent:"
echo "  $TARGET"
