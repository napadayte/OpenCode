#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-agent-doc <agent-slug>"
  echo
  echo "Example:"
  echo "  new-agent-doc security-reviewer"
  exit 1
fi

SLUG="$1"

case "$SLUG" in
  *[!a-z0-9-]*|"")
    echo "Agent slug must use only lowercase letters, numbers, and hyphens."
    echo "Example: security-reviewer"
    exit 1
    ;;
esac

# Find workspace root: nearest parent with AGENTS.md and either .claude/ or docs/.
ROOT="$PWD"
while [ "$ROOT" != "/" ]; do
  if [ -f "$ROOT/AGENTS.md" ] && { [ -d "$ROOT/.claude" ] || [ -d "$ROOT/docs" ]; }; then
    break
  fi
  ROOT="$(dirname "$ROOT")"
done

if [ "$ROOT" = "/" ]; then
  echo "Workspace root not found."
  echo "Run this inside an agent-ready workspace."
  exit 1
fi

# Canonical location for agents in a workspace.
mkdir -p "$ROOT/.claude/agents"
TARGET="$ROOT/.claude/agents/$SLUG.md"

if [ -e "$TARGET" ]; then
  echo "Agent already exists:"
  echo "  $TARGET"
  exit 1
fi

TITLE="$(echo "$SLUG" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) substr($i,2)}; print}')"

cat > "$TARGET" <<EOF2
---
name: $SLUG
description: "<one sentence purpose>. Use when: <triggers>. На русском: <ru triggers>. Українською: <ua triggers>."
model: sonnet
color: gray
tools:
  - Read
  - Glob
  - Grep
  - SendMessage
---

# $TITLE

## Purpose

<Describe what this agent is responsible for.>

## When to use

- <condition 1>
- <condition 2>
- <condition 3>

## Restrictions

This agent must not:

- edit files unless approved
- commit unless requested
- push unless requested
- expose secrets
- run destructive commands

## Output format

Return:

- summary
- findings
- risks
- recommendation
- next step
EOF2

echo "Created agent:"
echo "  $TARGET"
echo
echo "Next steps:"
echo "  1. Fill the YAML frontmatter (tools: whitelist — least privilege)."
echo "  2. Replace placeholders in the body."
echo "  3. Update AGENTS.md and .claude/agents/README.md so the role is discoverable."
echo "  4. If OpenCode should know it, add an entry under \"agent\" in opencode.json."
