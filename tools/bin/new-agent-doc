#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-agent-doc <agent-slug>"
  echo
  echo "Example:"
  echo "  new-agent-doc security-reviewer"
  exit 1
fi

SLUG="$1"

case "$SLUG" in
  *[!a-z0-9-]*|"")
    echo "Agent slug must use only lowercase letters, numbers, and hyphens."
    echo "Example: security-reviewer"
    exit 1
    ;;
esac

# Find workspace root: nearest parent with AGENTS.md and either .opencode/ or docs/.
ROOT="$PWD"
while [ "$ROOT" != "/" ]; do
  if [ -f "$ROOT/AGENTS.md" ] && { [ -d "$ROOT/.opencode" ] || [ -d "$ROOT/docs" ]; }; then
    break
  fi
  ROOT="$(dirname "$ROOT")"
done

if [ "$ROOT" = "/" ]; then
  echo "Workspace root not found."
  echo "Run this inside an agent-ready workspace."
  exit 1
fi

# Canonical location for agents in a workspace.
mkdir -p "$ROOT/.opencode/agents"
TARGET="$ROOT/.opencode/agents/$SLUG.md"

if [ -e "$TARGET" ]; then
  echo "Agent already exists:"
  echo "  $TARGET"
  exit 1
fi

TITLE="$(echo "$SLUG" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) substr($i,2)}; print}')"

cat > "$TARGET" <<EOF2
---
description: "<one sentence purpose>. Use when: <triggers>. На русском: <ru triggers>. Українською: <ua triggers>."
mode: primary
permission:
  edit: ask
  bash:
    "*": ask
    "git status*": allow
    "git diff*": allow
    "git log*": allow
    "git push*": deny
---

# $TITLE

## Purpose

<Describe what this agent is responsible for.>

## When to use

- <condition 1>
- <condition 2>
- <condition 3>

## Restrictions

This agent must not:

- edit files unless approved
- commit unless requested
- push unless requested
- expose secrets
- run destructive commands

## Output format

Return:

- summary
- findings
- risks
- recommendation
- next step
EOF2

echo "Created agent:"
echo "  $TARGET"
echo
echo "Next steps:"
echo "  1. Fill the description, mode (primary|subagent), and tighten permission."
echo "  2. Replace placeholders in the body."
echo "  3. Update AGENTS.md and .opencode/agents/README.md so the role is discoverable."
echo
echo "OpenCode frontmatter rules:"
echo "  - Do NOT add 'name:'  — name comes from filename"
echo "  - Do NOT add 'color: blue'/etc — only hex or theme tokens (primary/info/...)"
echo "  - Do NOT add 'model: sonnet' bare — use 'provider/model' format"
echo "  - Do NOT add 'tools: [array]' — use 'permission:' block instead"
