#!/usr/bin/env bash
set -euo pipefail

TEMPLATE="$HOME/.config/opencode/projects/templates/agent-ready-project"
CODE_DIR="$HOME/code"

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-agent-project <project-name>"
  echo
  echo "Example:"
  echo "  new-agent-project my-app"
  exit 1
fi

PROJECT_NAME="$1"
TARGET="$CODE_DIR/$PROJECT_NAME"

if [ ! -d "$TEMPLATE" ]; then
  echo "Template not found:"
  echo "  $TEMPLATE"
  exit 1
fi

if [ -e "$TARGET" ]; then
  echo "Project already exists:"
  echo "  $TARGET"
  exit 1
fi

mkdir -p "$CODE_DIR"
cp -a "$TEMPLATE" "$TARGET"

cd "$TARGET"

# Replace default title in README.
if [ -f README.md ]; then
  sed -i "s/^# Project Name/# $PROJECT_NAME/" README.md
fi

git init >/dev/null
git branch -M main

echo "Created agent-ready project:"
echo "  $TARGET"
echo
echo "Next steps:"
echo "  cd $TARGET"
echo "  edit README.md"
echo "  edit AGENTS.md"
echo "  edit docs/architecture.md"
echo "  opencode"
