#!/usr/bin/env bash
set -euo pipefail

# Resolve script location (follow symlinks) → derive repo root.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

TEMPLATE="$REPO_ROOT/projects/templates/agent-ready-project"
CODE_DIR="${OPENCODE_CODE_DIR:-$HOME/code}"

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-agent-project <project-name>"
  echo
  echo "Example:"
  echo "  new-agent-project my-app"
  exit 1
fi

PROJECT_NAME="$1"
TARGET="$CODE_DIR/$PROJECT_NAME"

if [ ! -d "$TEMPLATE" ]; then
  echo "Template not found:"
  echo "  $TEMPLATE"
  exit 1
fi

if [ -e "$TARGET" ]; then
  echo "Project already exists:"
  echo "  $TARGET"
  exit 1
fi

mkdir -p "$CODE_DIR"
mkdir -p "$TARGET"

# Safe copy via tar — exclude metadata, caches, secrets, archives.
(
  cd "$TEMPLATE"
  tar \
    --exclude='.git' \
    --exclude='node_modules' \
    --exclude='.cache' \
    --exclude='*.tar' \
    --exclude='*.tar.gz' \
    --exclude='*.zip' \
    --exclude='auth.json' \
    --exclude='oauth_creds.json' \
    --exclude='google_accounts.json' \
    -cf - .
) | (
  cd "$TARGET"
  tar -xf -
)

cd "$TARGET"

# Template-specific cleanup for .opencode/ adapter folder.
rm -f .opencode/package.json
rm -f .opencode/package-lock.json
rm -f .opencode/.gitignore

# Replace default title in README.
if [ -f README.md ]; then
  sed -i "s/^# Project Name/# $PROJECT_NAME/" README.md
fi

git init >/dev/null
git branch -M main

echo "Created agent-ready project:"
echo "  $TARGET"
echo
echo "Next steps:"
echo "  cd $TARGET"
echo "  edit README.md"
echo "  edit AGENTS.md"
echo "  edit docs/architecture.md"
echo "  opencode"
