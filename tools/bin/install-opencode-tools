#!/usr/bin/env bash
set -euo pipefail

# Resolve script location (follow symlinks) → derive repo's tools/bin directory.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
SRC="$(cd -P "$(dirname "$SOURCE")" && pwd)"

DEST="$HOME/.local/bin"
mkdir -p "$DEST"

for name in \
  new-agent-project \
  new-agent-workspace \
  new-agent-doc \
  new-skill-doc \
  capture-agent-asset \
  install-opencode-tools
do
  if [ -f "$SRC/$name" ]; then
    chmod +x "$SRC/$name"
    ln -sf "$SRC/$name" "$DEST/$name"
    echo "linked: $DEST/$name"
  else
    echo "missing: $SRC/$name"
  fi
done

echo
echo "Check PATH:"
echo '  echo "$PATH" | tr ":" "\n" | grep "$HOME/.local/bin"'
echo
echo "If missing, add this to ~/.bashrc:"
echo '  export PATH="$HOME/.local/bin:$PATH"'
