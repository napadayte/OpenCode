#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  capture-agent-asset <source-file> [asset-name]"
  echo
  echo "Example:"
  echo "  capture-agent-asset ~/Downloads/claude-rules.md claude-rules"
  exit 1
fi

SOURCE="$1"

if [ ! -f "$SOURCE" ]; then
  echo "Source file not found:"
  echo "  $SOURCE"
  exit 1
fi

# Find workspace root.
ROOT="$PWD"
while [ "$ROOT" != "/" ]; do
  if [ -f "$ROOT/AGENTS.md" ] && { [ -d "$ROOT/.claude" ] || [ -d "$ROOT/docs" ]; }; then
    break
  fi
  ROOT="$(dirname "$ROOT")"
done

if [ "$ROOT" = "/" ]; then
  echo "Workspace root not found."
  echo "Run this inside an agent-ready workspace."
  exit 1
fi

if [ $# -ge 2 ]; then
  NAME="$2"
else
  NAME="$(basename "$SOURCE")"
fi

SLUG="$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"

if [ -z "$SLUG" ]; then
  echo "Could not create slug. Provide asset name:"
  echo "  capture-agent-asset <source-file> useful-agent-rules"
  exit 1
fi

DATE="$(date +%Y-%m-%d_%H-%M)"
DIR="$ROOT/research/agent-assets/${DATE}_${SLUG}"

mkdir -p "$DIR"

EXT="${SOURCE##*.}"
cp "$SOURCE" "$DIR/source.$EXT"

# Lightweight type-hint heuristic on the source.
TYPE="mixed"
if grep -Eiq 'you are|agent|role|responsibilities' "$SOURCE"; then
  TYPE="agent-candidate"
fi
if grep -Eiq 'steps|workflow|pipeline|output format|when to use' "$SOURCE"; then
  if [ "$TYPE" = "agent-candidate" ]; then
    TYPE="mixed-agent-skill-candidate"
  else
    TYPE="skill-candidate"
  fi
fi
if grep -Eiq 'never|do not|ask before|dangerous|secrets|credentials' "$SOURCE"; then
  TYPE="$TYPE-with-rules"
fi

# Secret scan — flag, never print, names of patterns only.
SECRET_PATTERNS='(api[_-]?key|secret|token|password|bearer|authorization|client[_-]?secret|aws[_-]?(access|secret)|openai[_-]?api[_-]?key|anthropic[_-]?api[_-]?key|BEGIN[[:space:]]+(RSA|EC|DSA|OPENSSH|PRIVATE)[[:space:]]+KEY|postgres://[^/[:space:]]*:[^@[:space:]]*@|mysql://[^/[:space:]]*:[^@[:space:]]*@|mongodb(\+srv)?://[^/[:space:]]*:[^@[:space:]]*@|https://hooks\.slack\.com/services/|https://discord\.com/api/webhooks/)'

SECRET_HITS_FILE="$DIR/secret-scan.txt"
if grep -EnI -i "$SECRET_PATTERNS" "$SOURCE" > "$SECRET_HITS_FILE" 2>/dev/null; then
  SECRET_COUNT=$(wc -l < "$SECRET_HITS_FILE" | tr -d ' ')
  SECRET_STATUS="WARNING — $SECRET_COUNT potential secret pattern hit(s). See secret-scan.txt. Do NOT promote until reviewed."
else
  rm -f "$SECRET_HITS_FILE"
  SECRET_STATUS="No obvious secret patterns matched (still inspect manually)."
fi

cat > "$DIR/review.md" <<EOF2
# Agent Asset Review

## Source

Local source file (gitignored):

    source.$EXT

Captured at:

    $DATE

Suggested type:

    $TYPE

## Secret scan

    $SECRET_STATUS

## Decision

Status:

    pending

Decision:

    keep / reject / promote-agent / promote-skill / promote-rule / split

## What to extract

Look for:

- useful agent roles
- useful skills
- useful rules
- workflow steps
- output formats
- safety checks
- review checklists
- stop conditions
- edge cases

## What to reject

Reject:

- project-specific code instructions that do not apply
- framework-specific rules that are not needed
- vague motivational text
- unsafe automation
- secret-handling mistakes
- automatic push/commit behavior
- destructive behavior
- copied text that should be rewritten

## Promotion targets

Possible targets in this workspace:

    .claude/agents/<slug>.md
    .claude/skills/<slug>/SKILL.md
    .claude/rules/<slug>.md
    .claude/commands/<slug>.md
    checklists/<slug>.md

## Extraction prompt

Run \`/intake research/agent-assets/${DATE}_${SLUG}\` in OpenCode or Claude Code,
or use this manual prompt:

> Analyze research/agent-assets/${DATE}_${SLUG}/source.$EXT.
> Do not edit files.
> Extract only reusable ideas useful for this workspace.
> Classify each useful item as one of: agent / skill / rule / checklist / workflow / reject.
> For each useful item, return: type, proposed name, why useful, where it should go,
> rewritten content in our style, risks, recommendation.
> Do not copy large external text directly.
> Do not include secrets.
EOF2

echo "Captured agent asset:"
echo "  $DIR"
echo
echo "Review file:"
echo "  $DIR/review.md"
echo
echo "Raw source (gitignored as research/agent-assets/*/source.*):"
echo "  $DIR/source.$EXT"
echo
echo "Secret scan:"
echo "  $SECRET_STATUS"
echo
echo "Next:"
echo "  1. open $DIR/review.md"
echo "  2. Address any secret-scan findings before any further action."
echo "  3. Run /intake on the folder, or use the extraction prompt manually."
echo "  4. Promotion to .claude/ is MANUAL after user approval."
echo
echo "Run git status to confirm only research/agent-assets/*/review.md is tracked."
