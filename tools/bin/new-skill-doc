#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage:"
  echo "  new-skill-doc <skill-slug>"
  echo
  echo "Example:"
  echo "  new-skill-doc n8n-workflow-doc"
  exit 1
fi

SLUG="$1"

case "$SLUG" in
  *[!a-z0-9-]*|"")
    echo "Skill slug must use only lowercase letters, numbers, and hyphens."
    echo "Example: n8n-workflow-doc"
    exit 1
    ;;
esac

# Find workspace root.
ROOT="$PWD"
while [ "$ROOT" != "/" ]; do
  if [ -f "$ROOT/AGENTS.md" ] && { [ -d "$ROOT/.claude" ] || [ -d "$ROOT/docs" ]; }; then
    break
  fi
  ROOT="$(dirname "$ROOT")"
done

if [ "$ROOT" = "/" ]; then
  echo "Workspace root not found."
  echo "Run this inside an agent-ready workspace."
  exit 1
fi

# Skills live in .claude/skills/<slug>/SKILL.md (one directory per skill so the
# skill can later grow references/, examples/, supporting files).
SKILL_DIR="$ROOT/.claude/skills/$SLUG"
TARGET="$SKILL_DIR/SKILL.md"

if [ -e "$TARGET" ]; then
  echo "Skill already exists:"
  echo "  $TARGET"
  exit 1
fi

mkdir -p "$SKILL_DIR"

TITLE="$(echo "$SLUG" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) substr($i,2)}; print}')"

cat > "$TARGET" <<EOF2
---
name: $SLUG
description: "<one sentence purpose>. Use when: <triggers>. На русском: <ru triggers>. Українською: <ua triggers>."
allowed-tools: Read, Glob, Grep
risk: unknown
source: workspace
---

# $TITLE

## When to use

- <concrete trigger 1>
- <concrete trigger 2>

## Inputs needed

Identify before starting:

- <input 1>
- <input 2>

## Procedure

### 1. <First step>
<What to do, with concrete command or check.>

### 2. <Second step>
<...>

### 3. <Verification>
<How to know it worked.>

## Output

- <what the skill produces>
- <where it lands>

## Restrictions

- <safety rule 1>
- <safety rule 2>
EOF2

echo "Created skill:"
echo "  $TARGET"
echo
echo "Next steps:"
echo "  1. Fill the YAML frontmatter (risk: high for data/backup/external)."
echo "  2. Write a DISTINCT, concrete procedure — not generic boilerplate."
echo "  3. Update AGENTS.md and .claude/skills/README.md."
